doctype html
html
  head
    title= title
    style.
      body {
        font-family: sans-serif;
        padding: 40px;
        color: #33475b;
      }
      form {
        max-width: 400px;
        margin-top: 20px;
      }
      label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 4px;
        margin-top: 14px;
      }
      input {
        width: 100%;
        padding: 8px 10px;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 14px;
      }
      button {
        margin-top: 20px;
        padding: 10px 20px;
        background: pink;
        border: none;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
      }
  body
    a(href='/') Return to the homepage
    h1 Add a new record
    form(action='/update-cobj' method='POST')
      label Name
      input(type='text' name='name')
      label Make
      input(type='text' name='make')
      label Model
      input(type='text' name='model')
      button(type='submit') Submit